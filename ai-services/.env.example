# ─────────────────────────────────────────────
# AgroVision AI — Variables de entorno
# Copiar a .env y completar los valores
# ─────────────────────────────────────────────

# Entorno: development | production
ENV=development

# Puerto del servidor FastAPI
PORT=8000

# Nivel de logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── APIs externas ─────────────────────────────
# Obtener en https://openweathermap.org/api



# ── Redis (caché) ─────────────────────────────
# Si no hay Redis disponible el servicio funciona sin caché
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=3600

# ── Rutas internas ────────────────────────────
# Directorio donde se guardan los modelos ML (.pkl)
MODEL_DIR=/app/models

# Directorio donde se guardan los datasets procesados
DATASETS_DIR=/app/datasets
